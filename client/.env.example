# Frontend Environment Configuration

# ===== Local Network (student mic + voice) =====
# Use HTTPS dev server and Vite proxy so microphones work on other devices.
# 1. Leave VITE_SERVER_URL empty (uses same-origin proxy through Vite)
# 2. Start client: npm run dev
# 3. Open https://<server-ip>:5173 on every device (accept certificate warning)
# 4. Server CORS_ORIGIN must include https://<server-ip>:5173

VITE_SERVER_URL=
VITE_AUTH_API_URL=
VITE_DEV_HTTPS=true

# ===== Local Network (direct HTTP API — listen only on other devices) =====
# VITE_SERVER_URL=http://<server-machine-ip>:3000
# VITE_AUTH_API_URL=http://<server-machine-ip>:3000/auth
# VITE_DEV_HTTPS=false

# ===== Railway Deployment =====
# VITE_SERVER_URL=https://<railway-deployment-url>
# VITE_AUTH_API_URL=https://<railway-deployment-url>/auth
# VITE_DEV_HTTPS=false

# Force polling-only transport for Socket.IO (useful for some networks)
VITE_SOCKET_TRANSPORT_POLLING=false
